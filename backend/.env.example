NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://user:password@postgres:5432/collab_ide
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_value_generated_per_environment
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_value_generated_per_environment
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CLIENT_URL=https://your-frontend-domain.example.com
MAX_TERMINAL_SESSIONS=50
TERMINAL_IDLE_TIMEOUT_MS=600000

# ─── Demo Mode ──────────────────────────────────────────────────────────────
# Set to "true" on free-tier hosted deployments (Render, Railway, etc.) where
# Docker is unavailable. Disables the terminal, Run, Install, and workspace
# reset. All other features (auth, Yjs collaboration, replay, permissions,
# file explorer, notifications) continue working normally.
# Set to "false" (or remove) to restore full execution functionality.
DEMO_MODE=false
