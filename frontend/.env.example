# In local development with Vite proxy (default), leave these as-is.
# The Vite dev server proxies /api, /terminal, and /ws to localhost:4000,
# making everything same-origin so cookies work without HTTPS.
VITE_API_URL=/api
VITE_YJS_WS_URL=ws://localhost:5173
VITE_TERMINAL_WS_URL=ws://localhost:5173/terminal

# For production (nginx reverse proxy or separate domains):
# VITE_API_URL=https://api.your-domain.com/api
# VITE_YJS_WS_URL=wss://api.your-domain.com
# VITE_TERMINAL_WS_URL=wss://api.your-domain.com/terminal

# ─── Demo Mode ──────────────────────────────────────────────────────────────
# Set to "true" to hide Docker-dependent UI (terminal panel, Run button,
# Install button, runtime/network/reset controls in workspace settings).
# Must match the DEMO_MODE value set on the backend.
VITE_DEMO_MODE=false
